# =============================================================================
# Job Search Intelligence Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# .env is gitignored and will never be committed.
# See SETUP.md for detailed instructions on obtaining each value.

# =============================================================================
# REQUIRED — local stack won't work without these
# =============================================================================

# Dashboard login password (choose any password)
APP_PASSWORD=changeme

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=                 # pragma: allowlist secret

# Local PostgreSQL connection (auto-configured by docker-compose, usually no changes needed)
DATABASE_URL=postgresql://jobsearch:localdev@localhost:5433/jobsearch  # pragma: allowlist secret

# =============================================================================
# GMAIL OAUTH — required for email classification features
# =============================================================================
# Without these, the local stack still runs but email-dependent agents are disabled.
# See SETUP.md "Step 2: Gmail OAuth" for how to obtain these files.

GMAIL_CREDENTIALS_PATH=credentials/credentials.json
GMAIL_TOKEN_PATH=credentials/token.json

# =============================================================================
# AWS — required for cloud pipeline integration
# =============================================================================
# Without these, local-only features work but cloud integration is disabled.
# See SETUP.md "Step 3: AWS Infrastructure" for setup instructions.

# Your ALB URL (from terraform output after deploy)
CLOUD_API_URL=

# HMAC key for local-to-cloud authentication (must match Secrets Manager value)
# Generate with: openssl rand -hex 32
INGEST_HMAC_KEY=

# S3 bucket name for JD storage (created in AWS setup, must match terraform.tfvars)
S3_BUCKET=

# Bedrock Knowledge Base ID (created in AWS console)
BEDROCK_KB_ID=

# AWS region (default: us-east-2)
AWS_DEFAULT_REGION=us-east-2

# =============================================================================
# LOCAL SERVICES — defaults work with docker-compose, change only if needed
# =============================================================================

OLLAMA_BASE_URL=http://localhost:11434
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
MLFLOW_TRACKING_URI=http://localhost:5001
ONNX_MODEL_PATH=local/models/all-MiniLM-L6-v2

# =============================================================================
# OPTIONAL
# =============================================================================

# Resume upload API key (leave empty to disable auth on resume service)
RESUME_API_KEY=
RESUME_STORAGE_PATH=/tmp/resumes

# How often ECS polls for unanalyzed jobs (seconds, ECS only)
ANALYSIS_POLL_INTERVAL=60

# SQS queue name (usually matches terraform output)
SQS_QUEUE_NAME=job-search-platform-jd-scrape-queue

# Cookie security (set to false for local HTTP development)
SECURE_COOKIES=true
